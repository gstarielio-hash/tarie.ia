{
  "name": "tariel-inspetor-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:dev": "node ./scripts/fix-gradle-wrapper.cjs && node ./scripts/run-android-dev.cjs",
    "android:prebuild": "expo prebuild --platform android --clean && node ./scripts/fix-gradle-wrapper.cjs",
    "android:preview": "node ./scripts/fix-gradle-wrapper.cjs && node ./scripts/run-android-preview.cjs",
    "android:preview:fresh": "expo prebuild --platform android --clean && node ./scripts/fix-gradle-wrapper.cjs && node ./scripts/run-android-preview.cjs",
    "eas:build:android:preview": "npx eas build --platform android --profile preview",
    "eas:build:android:production": "npx eas build --platform android --profile production",
    "eas:build:ios:preview": "npx eas build --platform ios --profile preview",
    "eas:build:ios:production": "npx eas build --platform ios --profile production",
    "eas:submit:android:production": "npx eas submit --platform android --profile production",
    "eas:submit:ios:production": "npx eas submit --platform ios --profile production",
    "ios": "expo run:ios",
    "maestro:smoke": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run_mobile_maestro_smoke.ps1",
    "maestro:login": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run_mobile_maestro_smoke.ps1 -Flow android/maestro/login-smoke.yaml",
    "maestro:history": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run_mobile_maestro_smoke.ps1 -Flow android/maestro/history-smoke.yaml",
    "maestro:settings": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run_mobile_maestro_smoke.ps1 -Flow android/maestro/settings-smoke.yaml",
    "maestro:chat": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run_mobile_maestro_smoke.ps1 -Flow android/maestro/chat-smoke.yaml",
    "maestro:suite": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run_mobile_maestro_suite.ps1",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "expo": "~55.0.6",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.12",
    "expo-linear-gradient": "~55.0.8",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eas-cli": "^18.4.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
