SESSAO_TTL_HORAS=8
SESSAO_TTL_LEMBRAR_DIAS=30
SESSAO_MAX_POR_USUARIO=5
SESSAO_JANELA_RENOVACAO_MINUTOS=30
SESSAO_CHANCE_LIMPEZA=100
SESSAO_VINCULAR_USER_AGENT=0
SESSAO_VINCULAR_IP=0
