# Ambiente e aplicação
AMBIENTE=dev
PORTA=8000
APP_VERSAO=2.0-SaaS
APP_BUILD_ID=dev
APP_HOST_PUBLICO=127.0.0.1:8000
ALLOWED_HOSTS=localhost,127.0.0.1,::1,testserver
